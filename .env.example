# CryoBacktester — VPS sync configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# SSH connection to the CryoTrader production VPS.
# Defaults (hardcoded in sync_vps.py) match the production server — only set
# these if the server address or data path changes.
RECORDER_VPS_HOST=root@46.225.137.92
RECORDER_VPS_DATA_DIR=/opt/ct/recorder/data

# Path to your SSH private key. If unset, falls back to SSH_KEY below.
# RECORDER_SSH_KEY=~/.ssh/id_ed25519

# General SSH key fallback (used by sync_vps.py if RECORDER_SSH_KEY is not set).
SSH_KEY=~/.ssh/id_ed25519
